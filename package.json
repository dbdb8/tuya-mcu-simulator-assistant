{
  "name": "tuya-mcu-simulator-assistant",
  "private": true,
  "version": "0.1.3",
  "description": "Cross-platform assistant for simulating a Tuya-compatible MCU over serial.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dbdb8/tuya-mcu-simulator-assistant.git"
  },
  "homepage": "https://github.com/dbdb8/tuya-mcu-simulator-assistant",
  "bugs": "https://github.com/dbdb8/tuya-mcu-simulator-assistant/issues",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check && npm run build && npm run version:check && npm run privacy:check",
    "version:set": "node scripts/set-version.mjs",
    "version:check": "node scripts/verify-version.mjs",
    "privacy:check": "node scripts/check-public-content.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:updater": "tauri build --config src-tauri/tauri.release.conf.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.6.0",
    "@tauri-apps/plugin-dialog": "^2.3.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "i18next": "^26.3.6",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.4.11"
  }
}
