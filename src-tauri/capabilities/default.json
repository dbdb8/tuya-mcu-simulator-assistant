{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Tuya MCU Simulator Assistant",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://github.com/dbdb8/tuya-mcu-simulator-assistant/releases*" }]
    }
  ]
}
